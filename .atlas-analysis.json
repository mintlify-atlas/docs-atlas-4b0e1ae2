  "keyFeatures": [
    "Real-time SEO analysis with keyphrase optimization scoring",
    "Readability analysis with Flesch Reading Ease and sentence-level feedback",
    "XML sitemaps for pages, posts, categories, images, and videos",
    "Structured data (Schema.org) generation for rich search results",
    "Open Graph and Twitter Card metadata for social sharing",
    "Breadcrumb navigation with Schema.org BreadcrumbList markup",
    "Inclusive language analysis to improve content accessibility",
    "Multilingual support for 20+ languages",
    "WooCommerce integration with product-specific SEO checks",
    "Cornerstone content analysis with stricter SEO standards",
    "Internal linking suggestions and link count columns",
    "Indexables database for fast metadata access and crawl control",
    "AI-powered content improvement suggestions",
    "First-time configuration wizard for initial site setup",
    "Seamless integration with Elementor, WPML, and other plugins"
  ],
  "publicApiSurface": [
    "AnalysisWorkerWrapper (yoastseo npm package)",
    "AnalysisWebWorker (yoastseo npm package)",
    "Paper (yoastseo npm package)",
    "Assessment (yoastseo npm package)",
    "Assessor / SeoAssessor / ContentAssessor / TaxonomyAssessor (yoastseo npm package)",
    "Pluggable (YoastSEO.app.registerPlugin / registerModification)",
    "wpseo_title filter (PHP)",
    "wpseo_metadesc filter (PHP)",
    "wpseo_canonical filter (PHP)",
    "wpseo_robots filter (PHP)",
    "wpseo_schema_* filters (PHP)",
    "wpseo_breadcrumb_links filter (PHP)",
    "GET /wp-json/yoast/v1/get_head REST endpoint",
    "GET /wp-json/yoast/v1/indexing-stats REST endpoint",
    "Yoast\\WP\\SEO\\Values\\Meta_Tags_Context surface (PHP)"
  ]
